{
  "name": "smash-bros-battle",
  "version": "2.0.0",
  "bin": {
    "smash-bros-battle": "build/bin/smash-bros-battle.js"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "node --import=tsx node_modules/.bin/mocha 'test/**/*.test.ts'",
    "cdk": "cdk",
    "build:next": "cd next-app && yarn install --frozen-lockfile && yarn build",
    "deploy": "npm run build:next && npx cdk deploy"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1110.0",
    "chai": "^6.2.2",
    "esbuild": "^0.27.3",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "aws-cdk-lib": "^2.241.0",
    "cdk-nextjs-standalone": "^4.3.3",
    "constructs": "^10.5.0"
  }
}
